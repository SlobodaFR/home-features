# Copy this file to .env (never committed) and fill in the values.

# Required - central authentication service (auth.sloboda.fr)
AUTH_SERVICE_URL=https://auth.sloboda.fr
AUTH_CLIENT_ID=features
AUTH_CLIENT_SECRET=change-me

# Required - secret shared with auth-service for the revocation webhook
# (POST /api/auth/disconnect, query param "secret")
AUTH_WEBHOOK_SECRET=change-me

# Optional - frontend base URL, used for the OAuth2 redirect_uri and CORS config
FRONTEND_URL=http://localhost:3002

# Optional - path to the SQLite file
DATABASE_PATH=

# Optional
NODE_ENV=development
PORT=3002

# Optional - Litestream replication of the SQLite DB to MinIO (S3-compatible)
# If MINIO_BUCKET is set, the container restores the DB at startup and
# continuously replicates it.
MINIO_ENDPOINT=
MINIO_BUCKET=
MINIO_REPLICA_PATH=home-features
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY_ID=
MINIO_SECRET_ACCESS_KEY=
